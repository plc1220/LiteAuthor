# liteauthor_agent (LLM gateway — used by backend /ai, storycraft, and agent jobs)
# Default is direct in-process MLX. Use "openai" for an OpenAI-compatible HTTP server,
# or "google_genai" for Gemini autocomplete + Gemma chat (pip install -e './agent[gemini]').
LITEAUTHOR_LLM_PROVIDER=mlx
OPENAI_BASE_URL=http://127.0.0.1:8080/v1
OPENAI_API_KEY=not-needed
OPENAI_MODEL=default
# Optional fallback model for /ai/autocomplete when no in-process app bridge is available.
# In desktop builds, prefer exposing window.liteauthorAutocomplete for an embedded MLX model.
# OPENAI_AUTOCOMPLETE_MODEL=prism-ml/Ternary-Bonsai-1.7B-mlx-2bit

# Direct MLX provider defaults.
MLX_MODEL=Jackrong/MLX-Qwopus3.5-9B-v3-4bit
MLX_AUTOCOMPLETE_MODEL=prism-ml/Ternary-Bonsai-8B-mlx-2bit
MLX_AUTOCOMPLETE_BACKEND=lm

# google_genai provider (after: pip install -e './agent[gemini]')
# LITEAUTHOR_LLM_PROVIDER=google_genai
# GEMINI_API_KEY=   # paste the key string (AI Studio or GCP Console → APIs & Services → Credentials → API key).
#                   # Not a Secret Manager name. For Secret Manager, export in shell: GEMINI_API_KEY="$(gcloud secrets versions access latest --secret=YOUR_REAL_SECRET_ID)"
# GEMINI_AUTOCOMPLETE_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_CHAT_MODEL=gemma-4-26b-a4b-it
# Optional chat-only: LOW | HIGH (ThinkingConfig)
# GEMINI_CHAT_THINKING_LEVEL=HIGH
# GEMINI_CHAT_ENABLE_GOOGLE_SEARCH=true

# Scene packet size cap (characters) for context_engine
# LITEAUTHOR_MAX_CONTEXT_CHARS=12000

# Backend registry + projects (optional; defaults to ./data under repo root)
# LITEAUTHOR_DATA_DIR=/absolute/path/to/liteauthor-data
