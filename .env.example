# liteauthor_agent (LLM gateway — used by backend /ai and agent jobs)
OPENAI_BASE_URL=http://127.0.0.1:8080/v1
OPENAI_API_KEY=not-needed
OPENAI_MODEL=default
# Optional fallback model for /ai/autocomplete when no in-process app bridge is available.
# In desktop builds, prefer exposing window.liteauthorAutocomplete for an embedded MLX model.
# OPENAI_AUTOCOMPLETE_MODEL=prism-ml/Ternary-Bonsai-1.7B-mlx-2bit

# Scene packet size cap (characters) for context_engine
# LITEAUTHOR_MAX_CONTEXT_CHARS=12000

# Backend registry + projects (optional; defaults to ./data under repo root)
# LITEAUTHOR_DATA_DIR=/absolute/path/to/liteauthor-data
