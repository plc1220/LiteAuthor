# LiteAuthor backend — copy to `.env` in this folder and fill in values.
# Loaded automatically on API startup (see app/main.py).

# Optional: project registry + SQLite data (defaults to ../data from repo root)
# LITEAUTHOR_DATA_DIR=/absolute/path/to/liteauthor-data

# --- LLM gateway (liteauthor_agent; same vars as repo root .env.example) ---
# Default: MLX in-process. Alternatives: openai | google_genai
LITEAUTHOR_LLM_PROVIDER=mlx

# OpenAI-compatible server (when LITEAUTHOR_LLM_PROVIDER=openai)
OPENAI_BASE_URL=http://127.0.0.1:8080/v1
OPENAI_API_KEY=not-needed
OPENAI_MODEL=default
# OPENAI_AUTOCOMPLETE_MODEL=default

# MLX (when LITEAUTHOR_LLM_PROVIDER=mlx)
MLX_MODEL=Jackrong/MLX-Qwopus3.5-9B-v3-4bit
MLX_AUTOCOMPLETE_MODEL=prism-ml/Ternary-Bonsai-8B-mlx-2bit
MLX_AUTOCOMPLETE_BACKEND=lm

# Google GenAI (when LITEAUTHOR_LLM_PROVIDER=google_genai; pip install -e '../agent[gemini]')
# LITEAUTHOR_LLM_PROVIDER=google_genai
# GEMINI_API_KEY=
# GEMINI_AUTOCOMPLETE_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_CHAT_MODEL=gemma-4-26b-a4b-it
# GEMINI_CHAT_THINKING_LEVEL=HIGH
# GEMINI_CHAT_ENABLE_GOOGLE_SEARCH=true

# LITEAUTHOR_MAX_CONTEXT_CHARS=12000
